<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- Vanilla Vehicles Expanded patch to add airstrike for the Warbird -->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Vanilla Vehicles Expanded</li>
        </mods>
        <match Class="PatchOperationAdd">
            <xpath>Defs/Vehicles.VehicleDef[defName="VVE_Warbird"]/comps</xpath>
            <value>
                <li Class="AirstrikeMod.CompProperties_AirstrikePrecision">
                    <skyfallerBombing>ROCKET_BombingPass</skyfallerBombing>
                    <scatter>2</scatter>
                    <skillScatter>4</skillScatter>
                    <ordinance>
                        <li>Shell_HighExplosive</li>
                        <li>Shell_Incendiary</li>
                        <li>Shell_EMP</li>
                        <li>Shell_Smoke</li>
                        <li>Shell_Firefoam</li>
                        <li>Shell_AntigrainWarhead</li>
                        <li>ROCKET_Bomb_Explosive</li>
                        <li>ROCKET_Bomb_HighExplosive</li>
                        <li>ROCKET_Bomb_Incendiary</li>
                        <li>ROCKET_Bomb_Antigrain</li>
                    </ordinance>
                </li>
                <li Class="AirstrikeMod.CompProperties_AirstrikeStrafingRun">
                    <skyfallerBombing>ROCKET_BombingPass</skyfallerBombing>
                    <projectileDef>Bullet_AutocannonTurret</projectileDef>
                    <ammoDef>Steel</ammoDef>
                    <fireSound>Shot_Autocannon</fireSound>
                    <runWidth>3</runWidth>
                    <runLength>15</runLength>
                    <leadCells>8</leadCells>
                    <flyAltitude>2</flyAltitude>
                    <bulletsPerRound>4</bulletsPerRound>
                    <spreadCells>1</spreadCells>
                    <buzzSpeedMultiplier>0.7</buzzSpeedMultiplier>
                    <buzzSpeedRampCells>30</buzzSpeedRampCells>
                    <skillScatter>3</skillScatter>
                </li>
            </value>
        </match>
    </Operation>

    <!-- Vanilla Vehicles Expanded: upgrade Falcon to use VVE research, car-part components, and tier-2 stat extension -->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Vanilla Vehicles Expanded</li>
        </mods>
        <match Class="PatchOperationSequence">
            <operations>
                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleBuildDef[defName="ROCKET_Falcon_Blueprint"]/researchPrerequisites</xpath>
                    <value>
                        <researchPrerequisites>
                            <li>VVE_CombatVehicles</li>
                        </researchPrerequisites>
                    </value>
                </li>
                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleBuildDef[defName="ROCKET_Falcon_Blueprint"]/costList</xpath>
                    <value>
                        <costList>
                            <VVE_EngineBlock>4</VVE_EngineBlock>
                            <VVE_CarAlternator>2</VVE_CarAlternator>
                            <VVE_CarExhaust>4</VVE_CarExhaust>
                            <VVE_CarSuspension>3</VVE_CarSuspension>
                            <VVE_CarWheel>3</VVE_CarWheel>
                            <VVE_CarTransmission>1</VVE_CarTransmission>
                            <VVE_CarWiring>1</VVE_CarWiring>
                            <VVE_CarFuelTank>4</VVE_CarFuelTank>
                            <Steel>240</Steel>
                            <Plasteel>120</Plasteel>
                            <Silver>100</Silver>
                            <ComponentIndustrial>20</ComponentIndustrial>
                            <ComponentSpacer>4</ComponentSpacer>
                        </costList>
                    </value>
                </li>
                <li Class="PatchOperationAdd">
                    <xpath>Defs/Vehicles.VehicleDef[defName="ROCKET_Falcon"]</xpath>
                    <value>
                        <modExtensions>
                            <li Class="VanillaVehiclesExpanded.StatExtension">
                                <statToAdd>
                                    <li>VVE_VehicleTier</li>
                                </statToAdd>
                                <statValues>
                                    <li>VVE_Tier2</li>
                                </statValues>
                                <statDescriptions>
                                    <li>VVE_Tier2Desc</li>
                                </statDescriptions>
                            </li>
                        </modExtensions>
                    </value>
                </li>
            </operations>
        </match>
    </Operation>
</Patch>
